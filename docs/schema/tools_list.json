  {
    "name": "searchDomesticFlights",
    "title": "Search Domestic Flights",
    "description": "Search domestic Korea flights. Use ONLY when BOTH origin and destination are Korean cities (e.g. 제주, 부산, 김포, 대구, 광주, 여수). ⚠️ Do NOT use for overseas destinations (로마, 발리, 도쿄, 파리, 방콕 etc.) — use searchInternationalFlights instead. Airport codes: GMP(김포), CJU(제주), PUS(부산/김해), TAE(대구), KWJ(광주), RSU(여수), USN(울산), WJU(원주). Required params: origin (e.g. GMP), destination (e.g. CJU), departDate (YYYY-MM-DD). Default origin to GMP for domestic flights if not specified. All domestic routes are direct (no layovers). Results include real-time pricing and reservationUrl — always show both to users.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "tripType": {
          "type": "string",
          "enum": [
            "ONE_WAY",
            "ROUND_TRIP"
          ],
          "default": "ONE_WAY",
          "description": "Trip type (ONE_WAY: one-way, ROUND_TRIP: round-trip)"
        },
        "origin": {
          "type": "string",
          "default": "",
          "description": "Required. Origin airport code (3 letters, e.g., GMP, CJU). Cannot be null."
        },
        "destination": {
          "$ref": "#/properties/origin",
          "default": "",
          "description": "Required. Destination airport code (3 letters, e.g., GMP, CJU). Cannot be null."
        },
        "departDate": {
          "type": "string",
          "default": "",
          "description": "Required. Departure date (YYYYMMDD or YYYY-MM-DD). Must be after today."
        },
        "returnDate": {
          "$ref": "#/properties/departDate",
          "default": "",
          "description": "Return date (required for round-trip). Must be after today."
        },
        "passengers": {
          "type": "object",
          "properties": {
            "adults": {
              "type": "integer",
              "minimum": 1,
              "default": 1,
              "description": "Number of adults"
            },
            "children": {
              "type": "integer",
              "minimum": 0,
              "default": 0,
              "description": "Number of children (ages 2-11)"
            }
          },
          "additionalProperties": false,
          "default": {
            "adults": 1,
            "children": 0
          },
          "description": "Passenger counts"
        },
        "cabinClass": {
          "type": "string",
          "enum": [
            "ECONOMY",
            "BUSINESS"
          ],
          "default": "ECONOMY",
          "description": "Cabin class (domestic flights support ECONOMY and BUSINESS only)"
        },
        "maxResults": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 10,
          "description": "Maximum number of results (max: 100, default: 10)"
        }
      },
      "additionalProperties": false,
      "$schema": "http://json-schema.org/draft-07/schema#"
