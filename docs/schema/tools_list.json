  {
    "name": "searchInternationalFlights",
    "title": "Search International Flights",
    "description": "Search international flights (Korea to overseas). Use when destination is outside Korea. Common destinations: Tokyo(NRT/HND), Osaka(KIX), Bangkok(BKK), Bali(DPS), Singapore(SIN), Rome(FCO), Paris(CDG), London(LHR), New York(JFK), Hanoi(HAN), Danang(DAD), Cebu(CEB). ⚠️ Any city NOT in Korea = international flight. Required params: origin (IATA 3-letter, e.g. ICN), destination (IATA 3-letter, e.g. NRT), departDate (YYYY-MM-DD). If user doesn't specify airport, default origin to ICN for international flights. For round-trip: set tripType=ROUND_TRIP. returnDate defaults to departDate+4 if omitted. Results include real-time pricing and reservationUrl — always show both to users.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "tripType": {
          "type": "string",
          "enum": [
            "ONE_WAY",
            "ROUND_TRIP"
          ],
          "default": "ONE_WAY",
          "description": "Trip type (ONE_WAY: one-way, ROUND_TRIP: round-trip)"
        },
        "origin": {
          "type": "string",
          "default": "",
          "description": "Required. Origin airport IATA code (3 letters, e.g., ICN). Cannot be null."
        },
        "destination": {
          "$ref": "#/properties/origin",
          "default": "",
          "description": "Required. Destination airport IATA code (3 letters, e.g., NRT). Cannot be null."
        },
        "departDate": {
          "type": "string",
          "default": "",
          "description": "Required. Departure date (YYYYMMDD or YYYY-MM-DD). Must be after today."
        },
        "returnDate": {
          "$ref": "#/properties/departDate",
          "default": "",
          "description": "Return date (required for round-trip). Must be after today. Defaults to departDate + 4 days if omitted."
        },
        "passengers": {
          "type": "object",
          "properties": {
            "adults": {
              "type": "integer",
              "minimum": 1,
              "default": 1,
              "description": "Number of adults"
            },
            "children": {
              "type": "integer",
              "minimum": 0,
              "default": 0,
              "description": "Number of children (ages 2-11)"
            },
            "infants": {
              "type": "integer",
              "minimum": 0,
              "default": 0,
              "description": "Number of infants (under 2)"
            }
          },
          "additionalProperties": false,
          "default": {
            "adults": 1,
            "children": 0,
            "infants": 0
          },
          "description": "Passenger counts"
        },
        "cabinClass": {
          "type": "string",
          "enum": [
            "ECONOMY",
            "BUSINESS",
            "FIRST"
          ],
          "default": "ECONOMY",
          "description": "Cabin class"
        },
        "directFlightOnly": {
          "type": "boolean",
          "default": false,
          "description": "Search direct flights only when true"
        },
        "maxResults": {
          "type": "integer",
          "minimum": 1,
          "maximum": 250,
          "default": 5,
          "description": "Maximum number of results (max: 250, default: 5)"
        },
        "preferredAirline": {
          "type": "string",
          "default": "",
          "description": "Preferred airline code (2 letters, e.g., KE). Empty means no preference."
        }
      },
      "additionalProperties": false,
      "$schema": "http://json-schema.org/draft-07/schema#"
    },
    "annotations": {
      "readOnlyHint": true,
      "destructiveHint": false,
      "openWorldHint": true,
      "idempotentHint": true
    },
    "execution": {
      "taskSupport": "forbidden"
    },
