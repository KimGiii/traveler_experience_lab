  {
    "name": "getStayDetail",
    "description": "Get accommodation details including room types, per-room pricing, cancellation policies, amenities, and reviews. MUST be called after searchStays when user asks about a specific hotel, room types (룸 타입/객실/방 종류), room prices (객실 가격/방 가격), facilities (시설/편의시설), reviews (리뷰/후기), or wants detailed info (자세히/상세/알아봐줘). Requires gid from searchStays results. For queries mentioning a specific hotel name, call searchStays first to get the gid, then call this tool immediately.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "gid": {
          "type": "number",
          "description": "Accommodation GID (from searchStays results)"
        },
        "checkIn": {
          "type": "string",
          "description": "Check-in date (YYYY-MM-DD)"
        },
